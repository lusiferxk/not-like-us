# ============================================================
#   NOT-LIKE-US BACKEND  —  Environment Configuration Template
# ============================================================

# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
API_VERSION=v1

# ─── Admin Authentication ────────────────────────────────────
# Long random string used as the Bearer token for all /admin routes
ADMIN_SECRET=your_super_secret_admin_token_here_min_32_chars

# ─── PostgreSQL ──────────────────────────────────────────────
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=db_user
DB_PASSWORD=your_db_password_here

# Connection pool tuning
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# ─── AWS Credentials ─────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ─── AWS SQS Queue URLs ──────────────────────────────────────
SQS_ORDER_PROCESSING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/order-processing-queue
SQS_PAYMENT_SUCCESS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/payment-success-queue
SQS_EMAIL_NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/email-notification-queue

# SQS worker polling settings
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=10
SQS_VISIBILITY_TIMEOUT=60

# ─── AWS EventBridge Scheduler ───────────────────────────────
# IAM Role ARN that EventBridge Scheduler assumes to invoke targets
EVENTBRIDGE_SCHEDULER_ROLE_ARN=arn:aws:iam::123456789012:role/EventBridgeSchedulerRole

# ARN of the Lambda / SQS target EventBridge will invoke for cron tasks
EVENTBRIDGE_CRON_TARGET_ARN=arn:aws:lambda:us-east-1:123456789012:function:expire-orders-handler

# ─── PayHere IPG Merchant Credentials ────────────────────────
PAYHERE_MERCHANT_ID=1234567
PAYHERE_MERCHANT_SECRET=your_payhere_merchant_secret_here
PAYHERE_CURRENCY=LKR

# PayHere environment: 'sandbox' | 'production'
PAYHERE_ENV=sandbox

# Redirect URLs — must be publicly reachable
PAYHERE_RETURN_URL=https://yourdomain.com/order/success
PAYHERE_CANCEL_URL=https://yourdomain.com/order/cancel
# IMPORTANT: PayHere POSTs the webhook to this URL — must be your public API
PAYHERE_NOTIFY_URL=https://api.yourdomain.com/api/v1/payments/notify

# ─── Resend Email Gateway ─────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Verified sender address in your Resend domain
RESEND_FROM_ADDRESS=orders@yourdomain.com

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
